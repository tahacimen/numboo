<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- This whole style replaces the values/ one on API 27+, so it has to restate every item.
         Relying on the implicit "AppTheme." parent here would fall back to the action-bar theme
         and paint a 56dp bar across the top of the game. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">#090B17</item>
        <item name="android:navigationBarColor">#090B17</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
