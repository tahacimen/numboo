<meta charset="utf-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
/>
<meta name="theme-color" content="#0f0e17" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<title>NumDrop</title>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;900&display=swap"
  rel="stylesheet"
/>

<style>
  :root {
    --bg: #0f0e17;
    --surface: #1a1a2e;
    --cell-bg: #16213e;
    --cell-border: #0f3460;
    --accent1: #ff6b6b; /* red   - danger / wrong / forbidden / critical */
    --accent2: #ffd93d; /* gold  - highlight / active target / logo / score */
    --accent3: #6bcb77; /* green - positive / time-full / continue */
    --accent4: #4d96ff; /* blue  - level / next queue item */
    --text: #fffffe;
    --text-dim: #a7a9be;
    --bottom-row: rgba(255, 217, 61, 0.15);
    --bottom-border: #ffd93d;
    --freeze: #4dc8ff;
    --freeze-glow: #a0e9ff;
  }

  * {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    overscroll-behavior: none;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: "Nunito", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    font-weight: 600;
    -webkit-font-smoothing: antialiased;
    touch-action: manipulation;
    user-select: none;
    -webkit-user-select: none;
    display: flex;
    justify-content: center;
    min-height: 100%;
  }

  .app {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    padding: calc(10px + env(safe-area-inset-top)) 14px
      calc(14px + env(safe-area-inset-bottom)) 14px;
    gap: 12px;
    position: relative;
  }

  /* ---------- Header ---------- */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .logo {
    font-family: "Fredoka One", cursive;
    font-size: 2rem;
    letter-spacing: 2px;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent2), var(--accent1));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    white-space: nowrap;
  }

  .stats {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .stat-box {
    background: var(--surface);
    border: 1px solid var(--cell-border);
    border-radius: 10px;
    padding: 4px 8px;
    min-width: 48px;
    text-align: center;
    line-height: 1.1;
  }

  .stat-label {
    font-size: 0.58rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 700;
  }

  .stat-value {
    font-family: "Fredoka One", cursive;
    font-size: 1rem;
    color: var(--accent2);
  }

  .stat-badges .stat-value {
    color: var(--accent3);
  }
  .stat-level .stat-value {
    color: var(--accent4);
  }

  .sound-btn {
    background: var(--surface);
    border: 1px solid var(--cell-border);
    border-radius: 10px;
    color: var(--text);
    font-size: 1rem;
    padding: 4px 8px;
    cursor: pointer;
  }
  .sound-btn:active {
    transform: scale(0.92);
  }

  /* ---------- Queue ---------- */
  .queue-area {
    background: var(--surface);
    border: 1px solid var(--cell-border);
    border-radius: 14px;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .queue-label {
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
  }

  .queue-items {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .q {
    font-family: "Fredoka One", cursive;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    transition: all 0.2s ease;
  }
  .q.active {
    width: 46px;
    height: 46px;
    font-size: 1.7rem;
    color: var(--bg);
    background: var(--accent2);
    box-shadow: 0 0 14px rgba(255, 217, 61, 0.6);
  }
  .q.next {
    width: 34px;
    height: 34px;
    font-size: 1.1rem;
    color: var(--accent4);
    background: rgba(77, 150, 255, 0.15);
    border: 1px solid var(--accent4);
    opacity: 0.85;
  }
  .q.next2 {
    width: 28px;
    height: 28px;
    font-size: 0.9rem;
    color: var(--text-dim);
    background: rgba(167, 169, 190, 0.1);
    opacity: 0.55;
  }

  .remaining {
    font-size: 0.8rem;
    color: var(--text-dim);
    font-weight: 700;
  }

  .forbidden-box {
    margin-left: auto;
    display: none;
    align-items: center;
    gap: 6px;
    background: rgba(255, 107, 107, 0.12);
    border: 1px solid var(--accent1);
    border-radius: 10px;
    padding: 4px 10px;
  }
  .forbidden-box.show {
    display: flex;
  }
  .forbidden-box .fb-label {
    font-size: 0.62rem;
    color: var(--accent1);
    font-weight: 700;
    text-transform: uppercase;
  }
  .forbidden-box .fb-num {
    font-family: "Fredoka One", cursive;
    font-size: 1.2rem;
    color: var(--accent1);
  }

  /* ---------- Grid ---------- */
  .grid-wrap {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  #grid {
    width: 100%;
    max-width: 440px;
    aspect-ratio: 6 / 8;
    background: var(--surface);
    border: 2px solid var(--cell-border);
    border-radius: 16px;
    padding: 10px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(8, 1fr);
    gap: 6px;
  }

  .cell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Fredoka One", cursive;
    font-size: clamp(20px, 7vw, 34px);
    color: var(--text);
    background: var(--cell-bg);
    border: 1.5px solid var(--cell-border);
    border-radius: 10px;
    cursor: default;
    overflow: hidden;
  }

  .cell.bottom {
    background: var(--bottom-row);
    border-color: var(--bottom-border);
    cursor: pointer;
  }
  .cell.bottom:active {
    transform: scale(0.92);
    filter: brightness(1.2);
  }

  .cell.forbidden {
    background: rgba(255, 107, 107, 0.22);
    border-color: var(--accent1);
    color: var(--accent1);
    animation: dangerPulse 0.8s infinite alternate;
  }

  .cell.freeze {
    background: rgba(77, 200, 255, 0.18);
    border-color: var(--freeze);
    color: var(--freeze-glow);
    animation: freezeGlow 1s infinite alternate;
  }

  .cell.wrong {
    background: var(--accent1) !important;
    border-color: var(--accent1) !important;
    color: var(--bg) !important;
    animation: shake 0.3s;
  }

  .fbadge {
    position: absolute;
    top: 2px;
    right: 3px;
    font-size: 0.6rem;
    line-height: 1;
    font-family: "Nunito";
  }

  .cell .cnum.slide {
    animation: slideDown 0.22s ease-out;
  }

  /* ---------- Level-up flash ---------- */
  #levelup-flash {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Fredoka One", cursive;
    font-size: 2.6rem;
    color: var(--accent2);
    text-shadow: 0 0 20px rgba(255, 217, 61, 0.8);
    pointer-events: none;
    opacity: 0;
    z-index: 5;
  }
  #levelup-flash.pop {
    animation: levelPop 1s ease-out;
  }

  /* ---------- Combo ---------- */
  .combo-display {
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #combo-text {
    font-family: "Fredoka One", cursive;
    font-size: 1.1rem;
    letter-spacing: 1px;
  }
  #combo-text.pop {
    animation: comboPop 0.5s ease-out;
  }

  /* ---------- Time bar ---------- */
  .speed-wrap {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .speed-label {
    font-size: 0.68rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    display: flex;
    justify-content: space-between;
  }
  .speed-track {
    width: 100%;
    height: 16px;
    background: var(--cell-bg);
    border: 1px solid var(--cell-border);
    border-radius: 10px;
    overflow: hidden;
  }
  #speed-fill {
    height: 100%;
    width: 100%;
    border-radius: 10px;
    background: linear-gradient(90deg, var(--accent3), var(--accent2));
    transition: width 0.08s linear;
  }
  #speed-fill.mid {
    background: linear-gradient(90deg, var(--accent2), #ffa94d);
  }
  #speed-fill.critical {
    background: linear-gradient(90deg, var(--accent1), #ff8787);
    animation: blink 0.5s infinite;
  }
  #speed-fill.frozen {
    background: linear-gradient(90deg, var(--freeze), var(--freeze-glow));
    animation: none;
  }

  /* ---------- Overlays ---------- */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 14, 23, 0.92);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    z-index: 20;
  }
  .overlay.show {
    display: flex;
  }
  .overlay-box {
    background: var(--surface);
    border: 1px solid var(--cell-border);
    border-radius: 20px;
    padding: 28px 24px;
    max-width: 360px;
    width: 100%;
    text-align: center;
  }
  .overlay-title {
    font-family: "Fredoka One", cursive;
    font-size: 2.4rem;
    margin: 0 0 6px;
  }
  .overlay-title.logo-grad {
    background: linear-gradient(135deg, var(--accent2), var(--accent1));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 2px;
  }
  .overlay-sub {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 12px 0 22px;
    text-align: left;
  }
  .overlay-sub b {
    color: var(--text);
  }
  .final-score {
    font-family: "Fredoka One", cursive;
    font-size: 3rem;
    color: var(--accent2);
    margin: 8px 0 4px;
  }
  .final-sub {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .btn {
    font-family: "Fredoka One", cursive;
    font-size: 1.1rem;
    border: none;
    border-radius: 14px;
    padding: 14px 18px;
    width: 100%;
    color: var(--bg);
    cursor: pointer;
    background: var(--accent2);
    transition: transform 0.1s ease, filter 0.1s ease;
  }
  .btn:active {
    transform: scale(0.96);
  }
  .btn-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .btn-continue {
    background: linear-gradient(135deg, var(--accent3), #4dd98a);
  }
  .btn-continue:disabled {
    background: #2a2a40;
    color: var(--text-dim);
    cursor: not-allowed;
    filter: none;
  }
  .btn-quit {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--cell-border);
  }

  /* ---------- Score popup ---------- */
  .popup {
    position: absolute;
    font-family: "Fredoka One", cursive;
    font-size: 1.1rem;
    color: var(--accent2);
    pointer-events: none;
    z-index: 6;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.6);
    animation: floatUp 0.8s forwards;
  }

  /* ---------- Keyframes ---------- */
  @keyframes slideDown {
    from {
      transform: translateY(-105%);
      opacity: 0.3;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-6px);
    }
    40% {
      transform: translateX(6px);
    }
    60% {
      transform: translateX(-4px);
    }
    80% {
      transform: translateX(4px);
    }
  }
  @keyframes comboPop {
    0% {
      transform: scale(0.6);
      opacity: 0;
    }
    60% {
      transform: scale(1.25);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }
  @keyframes levelPop {
    0% {
      opacity: 0;
      transform: scale(0.4);
    }
    30% {
      opacity: 1;
      transform: scale(1.1);
    }
    70% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1.3);
    }
  }
  @keyframes dangerPulse {
    from {
      box-shadow: 0 0 2px rgba(255, 107, 107, 0.4);
    }
    to {
      box-shadow: 0 0 16px rgba(255, 107, 107, 0.9);
    }
  }
  @keyframes freezeGlow {
    from {
      box-shadow: 0 0 3px rgba(77, 200, 255, 0.4);
    }
    to {
      box-shadow: 0 0 18px rgba(160, 233, 255, 0.9);
    }
  }
  @keyframes floatUp {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(-50px);
      opacity: 0;
    }
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
</style>

<div class="app">
  <!-- Header -->
  <header class="header">
    <div class="logo">NumDrop</div>
    <div class="stats">
      <div class="stat-box stat-badges">
        <div class="stat-label">🏅 Rozet</div>
        <div class="stat-value" id="stat-badges">0</div>
      </div>
      <div class="stat-box stat-level">
        <div class="stat-label">Level</div>
        <div class="stat-value" id="stat-level">1</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Skor</div>
        <div class="stat-value" id="stat-score">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">En Yüksek</div>
        <div class="stat-value" id="stat-best">0</div>
      </div>
      <button class="sound-btn" id="sound-btn" title="Ses aç/kapa">🔊</button>
    </div>
  </header>

  <!-- Queue -->
  <div class="queue-area" id="queue-area">
    <span class="queue-label">Sıra</span>
    <div class="queue-items" id="queue-items"></div>
    <span class="remaining" id="remaining"></span>
    <div class="forbidden-box" id="forbidden-box">
      <span class="fb-label">🚫 Basma</span>
      <span class="fb-num" id="forbidden-num">–</span>
    </div>
  </div>

  <!-- Grid -->
  <div class="grid-wrap">
    <div id="grid"></div>
    <div id="levelup-flash"></div>
  </div>

  <!-- Combo -->
  <div class="combo-display">
    <span id="combo-text"></span>
  </div>

  <!-- Time bar -->
  <div class="speed-wrap">
    <div class="speed-label">
      <span id="speed-text">⏱ Süre</span>
    </div>
    <div class="speed-track">
      <div id="speed-fill"></div>
    </div>
  </div>
</div>

<!-- Start overlay -->
<div class="overlay show" id="start-overlay">
  <div class="overlay-box">
    <h1 class="overlay-title logo-grad">NumDrop</h1>
    <p class="overlay-sub">
      Alt satırda <b>Sıra</b> kutusundaki hedef rakamı bul ve dokun. 🎯<br /><br />
      • Doğru dokunuş: skor + süre + combo. Hızlı ol, çok kazan!<br />
      • <b>Tek yanlış dokunuş oyunu bitirir.</b> ⚠️<br />
      • Süre çubuğu sürekli erir — dokunarak doldur.<br />
      • Her 5 hedefte <b>level</b> atlar, +1 🏅 rozet kazanırsın.<br />
      • Level 2'den itibaren <b>🚫 yasak rakam</b> gelir — sakın basma!<br />
      • ❄️ dondurucu: süreyi 3 sn durdurur, +50 puan.<br />
      • Bittiğinde rozet harcayıp <b>kaldığın yerden devam</b> edebilirsin.
    </p>
    <button class="btn" id="start-btn">🎮 Başla</button>
  </div>
</div>

<!-- Game over overlay -->
<div class="overlay" id="gameover-overlay">
  <div class="overlay-box">
    <h1 class="overlay-title" style="color: var(--accent1)">💥 Bitti</h1>
    <div class="final-score" id="final-score">0</div>
    <div class="final-sub" id="final-sub"></div>
    <div class="btn-row">
      <button class="btn btn-continue" id="continue-btn">▶️ Devam Et</button>
      <button class="btn" id="replay-btn">🔄 Tekrar Oyna</button>
      <button class="btn btn-quit" id="quit-btn">✖ Bitir</button>
    </div>
  </div>
</div>

<script src="game.js"></script>
